@page "/GeneralSettings/{gameID:int}"
<!-- ניהול משתמשים - רק יוזר מחובר יכול להיכנס -->
@attribute [Authorize]
@inject HttpClient Http
@using AuthTemplate.Shared.Models;
@inject NavigationManager Nav;

@* העוטף הראשי שמכיל את הדשא *@
<div class="settings-page-wrapper">
   
    
<a href="./GamesList">בחזרה למשחקים שלי</a>
<h1>⚙️הגדרות כלליות️</h1>

@if (gameSettings != null)
{
    <label>שם המשחק:</label>  
    <div>
        @if (isEditingName == true)
        {
            @* מצב עריכה: תיבת טקסט שמקושרת לשם, וכפתור אישור *@
            <input type="text" @bind="gameSettings.gameName" />
            <input type="button" value="✔️" @onclick="(() => isEditingName = false)" style="background: none; border: none; cursor: pointer;" />
        }
        else
        {
            @* מצב תצוגה: טקסט רגיל (בתור תת-כותרת) וכפתור עיפרון *@
            <span>@gameSettings.gameName</span>
            <input type="button" value="✏️" @onclick="(() => isEditingName = true)" style="background: none; border: none; cursor: pointer;" />
        }
    </div>
    
    @* אזור הכרטיסים *@
    <div class="cards-container">

        @* כרטיס 1: זמן מענה *@
        <div class="setting-card">
            <h2 class="card-title">זמן מענה לשאלה</h2>
        
            <div class="input-row">
                @* פקד מספר: מקושר לזמן, עם מינימום, מקסימום וקפיצות של 5. ננעל (disabled) אם סומן "ללא הגבלה" *@
                <input type="number" 
                       @bind="gameSettings.time" 
                       min="45" max="180" step="5" 
                       disabled="@isUnlimitedTime"
                       class="time-input"
                       />
                <span>שניות</span>

                @* צ'קבוקס ללא הגבלה *@
                <div class="checkbox-wrapper">
                    <input type="checkbox" id="unlimited" @bind="isUnlimitedTime" />
                    <label for="unlimited">ללא הגבלה</label>
                </div>
            </div>
        </div>

        @* כרטיס 2: שיקוי הצלה *@
        <div class="setting-card">
            <h2 class="card-title">שיקוי הצלה</h2>
            <div class="input-row">
                @* צ'קבוקס שמקושר ישירות לשדה של השיקוי בבסיס הנתונים *@
                <input type="checkbox" id="potion" @bind="gameSettings.hasPotion" class="potion-checkbox" />
                <label for="potion">השחקן יקבל שיקוי הצלה במשחק</label>
            </div>
        </div>

    </div>
   
}
else
{
    <p>טוען נתונים...</p>
}

<br />
@* כפתור השמירה שיפעיל את פונקציית העדכון מול הקונטרולר *@
<input type="button" value="שמירה" @onclick="SaveSettingsAndMove" />

<p>@msg</p>
    <div class="worm-area" aria-hidden="true">
        <div class="speech-bubble">
            ההגדרות האלה יעזרו לי,<br/> והן לכל המשחק
        </div>
    @* הוספנו את התולעת והסתרנו מקוראי מסך לטובת נגישות *@
        <img src="SVG/SilkyForSettings.svg" class="worm-character" alt="" aria-hidden="true" />
    </div>
</div> <!-- סגירת העוטף הראשי של העמוד -->

@code
{
    //הפרמטר שמוזרק בנתיב
    [Parameter]
    public int gameID { get; set; } 
    
    // מופע של ה-DTO שמכיל את נתוני המשחק 
    GameToAddDto gameSettings;
    
    // משתנה בוליאני שעוזר לנו לבדוק אם אנחנו במצב עריכה או בתצוגה רגילה
    bool isEditingName = false;
    //משתנה בוליאני שנועד לעזור לנו לאפשרות של בלי הגבלת זמן
    bool isUnlimitedTime = false;

    // עם טעינת העמוד
    protected override async Task OnInitializedAsync()
    {
        // קריאה לקונטרולר שיביא את המשחק הספציפי
        var response = await Http.GetAsync("api/Games/byId/" + gameID.ToString());
        if (response.IsSuccessStatusCode == true)
        {
            gameSettings = response.Content.ReadFromJsonAsync<GameToAddDto>().Result;
        }
    }
    
    string msg = "";
//פונקציה שפונה לקונטרולר שמעדכן את הפרטים שקשורים להגדרות הכלליות: שם המשחק, זמן, שיקוי
    async Task SaveSettingsAndMove()
    {
        //  אם המשתמש סימן ללא הגבלה, אנחנו משנים את ערך הזמן ל-1000
        if (isUnlimitedTime == true)
        {
            gameSettings.time = 1000;
        }
        // שליחת בקשת POST לנתיב שיצרנו, תוך שרשור ה-ID ושליחת האובייקט המעודכן
        var updateResponse = await Http.PostAsJsonAsync("api/Games/updateGame/" + gameID.ToString(), gameSettings);
//בדיקה אם העדכון הצליח        
        if (updateResponse.IsSuccessStatusCode == true)
        {
            msg = "השינויים נשמרו בהצלחה!";
            Nav.NavigateTo("./QuestionsEditor/" + gameID.ToString());
        }
        else 
        {
            // אם העדכון נכשל, נקרא את השגיאה שהשרת החזיר
            msg = updateResponse.Content.ReadAsStringAsync().Result;
        }
    }
  }
